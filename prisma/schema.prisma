generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                String    @default("member")
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  assignedDeals Deal[]
  activities    Activity[]
  auditLogs     AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  targetId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model RateLimitEntry {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime @default(now())
}

model TokenBlacklist {
  jti       String   @id
  expiresAt DateTime
}

model Tier {
  id       String    @id @default(cuid())
  label    String    @unique // default: "T1", "T2", "T3" — renamable
  order    Int
  contacts Contact[]
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String       @default("#6366f1")
  contactTags ContactTag[]
}

model Contact {
  id               String     @id @default(cuid())
  name             String
  email            String?
  phone            String?
  telegramUsername String?
  twitterHandle    String?
  companyName      String?
  status           String     @default("not_contacted") // drives which section contact appears in
  pocUsername      String?
  groupLink        String?
  logoUrl          String?
  tierId           String?
  notes            String?
  customFields     Json       @default("{}")
  pocs             Json       @default("[]")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tier         Tier?         @relation(fields: [tierId], references: [id])
  contactTags  ContactTag[]
  deals        Deal[]
  activities   Activity[]
  listContacts ListContact[]

  @@index([status])
  @@index([tierId])
  @@index([createdAt])
}

model List {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  contacts  ListContact[]

  @@map("lists")
}

model ListContact {
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    List    @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@map("list_contacts")
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model PipelineStage {
  id    String @id @default(cuid())
  name  String @unique
  order Int
  color String @default("#6366f1")
  deals Deal[]
}

model Deal {
  id           String    @id @default(cuid())
  contactId    String
  stageId      String?
  ownerId      String?
  notes        String?
  description  String?
  latestStatus String?
  callDate     DateTime?
  meetLink     String?
  customFields Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contact    Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stage      PipelineStage? @relation(fields: [stageId], references: [id])
  owner      User?          @relation(fields: [ownerId], references: [id])
  activities Activity[]
  tasks      Task[]

  @@index([contactId])
  @@index([stageId])
  @@index([ownerId])
}

model Task {
  id        String    @id @default(cuid())
  title     String
  completed Boolean   @default(false)
  dueAt     DateTime?
  dealId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([completed])
  @@map("tasks")
}

model CustomFieldDefinition {
  id        String @id @default(cuid())
  name      String
  fieldType String // "text" | "number" | "date" | "url" | "select"
  appliesTo String // "contact" | "deal"
  options   Json   @default("[]") // for select type
  order     Int    @default(0)

  @@unique([name, appliesTo])
}

model Activity {
  id          String   @id @default(cuid())
  type        String   // "note" | "call" | "email" | "telegram" | "twitter" | "meeting"
  body        String?
  attachments Json     @default("[]")
  contactId   String?
  dealId      String?
  userId      String?
  createdAt   DateTime @default(now())

  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])

  @@index([dealId])
  @@index([contactId])
}
